// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPER_ADMIN
  USER
}
enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}
model Apartment { // 아파트
  id                      String    @id @default(uuid())
  name                    String    @unique
  address                 String
  description             String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime       @updatedAt
  buildings        Int[]   // [101, 102, 104]
  units   Int[]
  floorCountPerBuilding  Int
  unitCountPerFloor      Int
  officeNumber String
  residents Resident[]  // 👈 주민들
  adminId     String    @unique
  admin       User      @relation(fields: [adminId], references: [id])
}

//---------------------------------------------------
model User {
  id        String   @unique @id @default(uuid())
  email     String   @unique
  name      String
  username  String    @unique
  contact   String    @unique
  password  String
  role      Role
  hasNext   Boolean  @default(false)
  joinStatus JoinStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime       @updatedAt
  approvedAt DateTime? 
  isActive  Boolean  @default(true)
  avatar    String?
  adminOf   Apartment?
  resident  Resident?
}

model Resident { // 입주민 거주지 정보
  id          String   @id @default(uuid())
  name        String  
  building    String
  unit        String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime       @updatedAt

  isHouseholder Boolean @default(false)
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, apartmentId], name: "userId_apartmentId")
}
