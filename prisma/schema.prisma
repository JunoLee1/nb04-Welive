// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
  USER
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

model Apartment {
  id                    String     @id @default(uuid())
  name                  String     @unique
  address               String
  description           String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  buildingNumberFrom    Int
  buildingNumberTo      Int
  floorCountPerBuilding Int
  unitCountPerFloor     Int
  officeNumber          String
  residents             Resident[] // 👈 주민들
  adminId               String     @unique
  admin                 User       @relation(fields: [adminId], references: [id])
}

//---------------------------------------------------
model User {
  id         String     @id @unique @default(uuid())
  email      String     @unique
  name       String
  username   String     @unique
  contact    String     @unique
  password   String
  role       Role
  hasNext    Boolean    @default(false)
  joinStatus JoinStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  approvedAt DateTime?
  isActive   Boolean    @default(true)
  avatar     String?
  adminOf    Apartment?
  resident   Resident?
}

model Resident {
  id        String   @id @default(uuid())
  name      String
  building  Int
  unit      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isHouseholder Boolean   @default(false)
  apartmentId   String
  apartment     Apartment @relation(fields: [apartmentId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}
